    private async void tmrPoll_Tick(object sender, EventArgs e)
    {
        tmrPoll.Stop(); // Prevent re-entry
        try
        {
            var jobs = await _api.GetPendingJobsAsync();
            _pendingJobs = jobs;
            UpdateJobGrid();
            UpdateDeviceStatus();
            lblApiStatus.Text = "OK";
        }
        catch (Exception ex)
        {
            lblApiStatus.Text = "Error";
            Log("Poll error: " + ex.Message);
