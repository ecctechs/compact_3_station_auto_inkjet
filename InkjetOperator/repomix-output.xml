                dlg.Filter = "JSON Files (*.json)|*.json|All Files (*.*)|*.*";
                dlg.Title = "Select Database File";

                if (dlg.ShowDialog() == DialogResult.OK)
                {
                    txtDbPath.Text = dlg.FileName;
                }
            }
        }

        // ================= SAVE =================
